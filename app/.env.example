# ─────────────────────────────────────────────────────────────────────
# xmr.irish v5 — data layer environment flags
# Copy to `.env` (or `.env.local`) and adjust. All keys are optional.
# ─────────────────────────────────────────────────────────────────────

# Activate the LIVE xmr.irish feed (useXmrIrishFeed) instead of the built-in
# simulator. Leave empty/unset for the simulated dev default. Any non-empty
# value enables it (e.g. 1). Production builds should set this.
VITE_LIVE_DATA=

# Dev-only: the live v4 origin the Vite dev server proxies /api and /ws to,
# so `npm run dev` talks to real endpoints SAME-ORIGIN (no CORS). Defaults to
# https://xmr.irish. Point this at a local stack to develop against it, e.g.
# VITE_API_ORIGIN=http://localhost:3001
VITE_API_ORIGIN=https://xmr.irish

# Optional explicit relay WebSocket URL. When unset, the feed derives it from
# the page origin (http→ws) + "/ws". Set this if the relay lives elsewhere,
# e.g. VITE_RELAY_WS=wss://relay.xmr.irish/ws
VITE_RELAY_WS=
