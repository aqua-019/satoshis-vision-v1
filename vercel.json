{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "satoshis-vision",
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.bunny.net; img-src 'self' data: https://api.coingecko.com; connect-src 'self' wss://relay.xmr.irish https://api.coingecko.com https://xmrchain.net https://localmonero.co; font-src 'self' https://fonts.bunny.net; frame-src https://changenow.io https://widget.changenow.io https://wagyu.xyz; object-src 'none'; base-uri 'self';"
        },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "functions": {
    "api/monero.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/home", "destination": "/" },
    { "source": "/archive", "destination": "/bottom-line.html" },
    { "source": "/education", "destination": "/btc-xmr-education.html" },
    { "source": "/mine", "destination": "/mining.html" },
    { "source": "/pool", "destination": "/mempool.html" },
    { "source": "/net", "destination": "/network.html" },
    { "source": "/market", "destination": "/markets.html" },
    { "source": "/eco", "destination": "/ecosystem.html" },
    { "source": "/law", "destination": "/legal.html" },
    { "source": "/people", "destination": "/community.html" },
    { "source": "/swap", "destination": "/hold-monero.html" },
    { "source": "/quotes", "destination": "/quotes.html" },
    { "source": "/secrets", "destination": "/secrets.html" },
    { "source": "/timeline", "destination": "/timeline.html" },
    { "source": "/outlook", "destination": "/future-outlook.html" },
    { "source": "/dashboard", "destination": "/markets" },
    { "source": "/privacy", "destination": "/privacy-architecture.html" },
    { "source": "/api/xmr/:path*", "destination": "https://relay.xmr.irish/api/:path*" }
  ],
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true }
  ]
}
